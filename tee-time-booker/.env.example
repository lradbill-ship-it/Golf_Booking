# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored and must NEVER be committed.

# Your golf club member-portal login credentials.
GOLF_USERNAME=your-member-username-or-email
GOLF_PASSWORD=your-password

# Optional: where to send a notification when a booking succeeds or fails.
# Leave blank to disable. (See notify.py for supported channels.)
NOTIFY_WEBHOOK_URL=
